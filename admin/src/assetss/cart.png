  .cropRect .leftTop, .cropRect .rightTop, .cropRect .leftBottom, .cropRect=
 .rightBottom, .ltr .cropRect .leftTop, .ltr .cropRect .leftBottom, .ltr .c=
ropRect .rightTop, .ltr .cropRect .rightBottom, .rtl .cropRect .leftTop, .r=
tl .cropRect .leftBottom, .rtl .cropRect .rightTop, .rtl .cropRect .rightBo=
ttom { border-color: canvas; forced-color-adjust: auto; }
