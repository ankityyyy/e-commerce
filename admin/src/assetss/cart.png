5, 255); }

.cropRect .leftBottom, .cropRect .rightBottom { border-bottom: 4px solid rg=
b(255, 255, 255); }

.ltr .cropRect .leftTop, .ltr .cropRect .leftBottom { border-left: 4px soli=
d rgb(255, 255, 255); }

.ltr .cropRect .rightTop, .ltr .cropRect .rightBottom { border-right: 4px s=
olid rgb(255, 255, 255); }

.rtl .cropRect .leftTop, .rtl .cropRect .leftBottom { border-right: 4px sol=
id rgb(255, 255, 255); }

.rtl .cropRect .rightTop, .rtl .cropRect .rightBottom { border-left: 4px so=
lid rgb(255, 255, 255); }

