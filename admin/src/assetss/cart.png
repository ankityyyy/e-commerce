en; direction: ltr; }

.sw_meIc::after, .idp_ham::after, .idp_wlid::after { position: relative; tr=
ansform: scale(0.5); display: inline-block; }

.idp_ham { height: 16px; width: 20px; vertical-align: top; top: 17px; }

