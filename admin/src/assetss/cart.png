running showCropBoxContent; }

.cropRect .content.end { background-color: rgba(0, 0, 0, 0); }

.cropBoxHint.start { animation: 0.5s ease-out 3s 1 normal forwards running =
fadeHint; }

.cropBoxHint.end { opacity: 0; }

