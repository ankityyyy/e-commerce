.cropRect .top, .cropRect .bottom { height: 6px; width: 100%; }

.cropRect .leftTop, .cropRect .rightTop, .cropRect .leftBottom, .cropRect .=
rightBottom { height: 16px; width: 16px; }

.cropRect .top { top: -4px; }

.cropRect .leftTop, .cropRect .rightTop { top: -1.5px; }

.cropRect .bottom { bottom: -4px; }

.cropRect .leftBottom, .cropRect .rightBottom { bottom: -1.5px; }

