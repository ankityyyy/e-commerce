.idp_ham::after { transform-origin: -274px -40px; }

.idp_ham:hover::after, .idp_ham:active::after, .idp_ham:focus::after { tran=
sform-origin: -318px -40px; }

.idp_wlid, .sw_meIc { height: 18px; width: 18px; }

.idp_wlid::after { transform-origin: -48px 0px; }

